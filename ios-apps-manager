========================= */
function iam_register_post_type() {
    $labels = array(
        'name'               => 'تطبيقات iOS',
        'singular_name'      => 'تطبيق iOS',
        'menu_name'          => 'تطبيقات iOS',
        'add_new'            => 'إضافة جديد',
        'add_new_item'       => 'إضافة تطبيق جديد',
        'edit_item'          => 'تعديل التطبيق',
        'new_item'           => 'تطبيق جديد',
        'view_item'          => 'عرض التطبيق',
        'search_items'       => 'بحث عن تطبيق',
        'not_found'          => 'لا توجد تطبيقات',
        'not_found_in_trash' => 'لا توجد تطبيقات في السلة',
    );

    $args = array(
        'labels'        => $labels,
        'public'        => true,
        'has_archive'   => true,
        'menu_icon'     => 'dashicons-smartphone',
        'supports'      => array('title', 'editor', 'thumbnail', 'excerpt'),
        'rewrite'       => array('slug' => 'ios-apps'),
        'show_in_rest'  => true,
    );

    register_post_type('ios_app', $args);
}
add_action('init', 'iam_register_post_type');

/* =========================
   إضافة الحقول المخصصة
========================= */
function iam_add_meta_boxes() {
    add_meta_box(
        'iam_app_details',
        'بيانات التطبيق',
        'iam_meta_box_callback',
        'ios_app',
