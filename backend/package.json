{
  "name": "developer-certificates-backend",
  "version": "1.0.0",
  "description": "Backend API for Developer Certificates and UDID Registration System",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "certificates",
    "udid",
    "authentication"
  ],
  "author": "tawbb52",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.0.3",
    "cors": "^2.8.5",
    "express-validator": "^7.0.0",
    "morgan": "^1.10.0",
    "helmet": "^7.0.0",
    "swagger-ui-express": "^4.6.2",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^18.11.9",
    "@types/jest": "^29.2.3",
    "typescript": "^5.0.0",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.3.1",
    "ts-jest": "^29.0.3",
    "eslint": "^8.28.0",
    "@typescript-eslint/eslint-plugin": "^5.42.0",
    "@typescript-eslint/parser": "^5.42.0",
    "prettier": "^2.8.0"
  }
}
